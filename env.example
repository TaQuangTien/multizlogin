# Ports (host port mapping)
APP_PORT=3000
VNC_PORT=7900

# Selenium / noVNC
START_XVFB=true
VNC_NO_PASSWORD=1
SCREEN_WIDTH=1280
SCREEN_HEIGHT=800

# Web UI Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here

# API Key (dùng để xác thực REST API qua header X-API-KEY)
X_API_KEY=your_secret_api_key_here

# Session secret (chuỗi ngẫu nhiên để mã hóa session)
SESSION_SECRET=your_random_session_secret

# Zalo Settings
# true: nhận lại tin nhắn do chính bot gửi (cần thiết để detect isAPI)
SELF_LISTEN=true
# Khoảng thời gian định kỳ kéo task từ GAS (đơn vị: giây)
PULL_INTERVAL=60

# Selenium Node
SE_NODE_MAX_SESSIONS=1
SE_NODE_SESSION_TIMEOUT=300

# Application Version
APP_VERSION=4.20260522
